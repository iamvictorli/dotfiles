{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "external_directory": {
      "*": "ask",
      "~/.config/opencode/**": "allow",
      "~/dotfiles/**": "allow",
      "~/workspace/**": "allow",
    },
    "read": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny",
      "*.envrc": "deny",
      "secrets/*": "deny",
      ".dev.vars": "ask"
    },
    "bash": {
      "*": "ask",
      "ast-grep *": "allow",
      "awk *": "allow",
      "biome *": "allow",
      "bun *": "allow",
      "cargo *": "allow",
      "cat *": "allow",
      "cloc *": "allow",
      "cp *": "allow",
      "date *": "allow",
      "diff *": "allow",
      "doggo *": "allow",
      "dot *": "allow",
      "fd *": "allow",
      "find *": "allow",
      "fnm *": "allow",
      "fzf *": "allow",
      "git *": "allow",
      "git push *": "ask",
      "git push": "ask",
      "go *": "allow",
      "grep *": "allow",
      "gsed *": "allow",
      "head *": "allow",
      "jj *": "allow",
      "jj git push *": "ask",
      "jj git push": "ask",
      "jj gp *": "ask",
      "jj gp": "ask",
      "jq *": "allow",
      "ls *": "allow",
      "mkdir *": "allow",
      "npm *": "allow",
      "pnpm *": "allow",
      "prettier *": "allow",
      "pwd": "allow",
      "rg *": "allow",
      "sed *": "allow",
      "sg *": "allow",
      "shellcheck *": "allow",
      "sort *": "allow",
      "stow *": "allow",
      "stylua *": "allow",
      "tail *": "allow",
      "tar *": "allow",
      "touch *": "allow",
      "tr *": "allow",
      "tree *": "allow",
      "tsc *": "allow",
      "turbo *": "allow",
      "uniq *": "allow",
      "unzip *": "allow",
      "vite *": "allow",
      "vitest *": "allow",
      "wc *": "allow",
      "which *": "allow",
      "xargs *": "allow",
      "yarn *": "allow",
      "z *": "allow",
      "zip *": "allow",
      "zoxide *": "allow",
    },
    "edit": "allow",
    "webfetch": "ask"
  },
  "theme": "tokyonight",
  "keybinds": {
    "leader": "ctrl+o",
    "messages_half_page_up": "ctrl+u",
    "messages_half_page_down": "ctrl+d",
    "input_delete_to_line_start": "none",
    "input_delete": "delete,shift+delete"
  },
  "mcp": {
    "grep_app": {
      "type": "remote",
      "url": "https://mcp.grep.app",
      "enabled": true
    },
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": true
    },
    "opensrc": {
      "type": "local",
      "command": [
        "node",
        "{env:HOME}/dotfiles/opensrc-mcp/dist/index.mjs"
      ],
      "enabled": true
    },
    "overseer": {
      "type": "local",
      "command": [
        "node",
        "{env:HOME}/dotfiles/overseer/mcp/build/index.js"
      ],
      "environment": {
        "OVERSEER_CLI_PATH": "{env:HOME}/dotfiles/overseer/overseer/target/release/os"
      },
      "enabled": true
    }
  }
}
